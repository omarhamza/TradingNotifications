<Project>
  <PropertyGroup>
    <WebPublishMethod>ZipDeploy</WebPublishMethod>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://tradingnotifications.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ResourceId>/subscriptions/0a06d1cd-bc6d-4339-8b45-6dc7f805b5cb/resourceGroups/Trading/providers/Microsoft.Web/sites/TradingNotifications</ResourceId>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
